rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function isValidImage() {
      return request.resource.contentType.matches('image/.*') &&
             request.resource.size <= 5 * 1024 * 1024 && // 5MB max
             request.resource.size > 0;
    }

    // User profile and ID images
    match /users/{userId}/{imageType} {
      allow read: if isAuthenticated();
      allow create, update: if isAuthenticated() &&
                           isOwner(userId) &&
                           isValidImage() &&
                           (imageType == 'profile.jpg' || imageType == 'id.jpg');
      allow delete: if isAuthenticated() && isOwner(userId);
    }

    // Category images
    match /categories/{categoryId}/{imageType} {
      allow read: if true;
      allow write: if false; // Only through admin SDK
    }

    // Product images
    match /products/{productId}/{imageType} {
      allow read: if true;
      allow create, update: if isAuthenticated() && isValidImage();
      allow delete: if isAuthenticated();
    }
  }
} 